# App Configuration
PORT=3000
NODE_ENV=development

# Database
# For local PostgreSQL, you can use: postgresql://user:password@localhost:5432/cybership
DATABASE_URL="postgresql://cybership:cybership@localhost:5432/cybership?schema=public"

# UPS API Integration
# Get these from UPS Developer Portal: https://developer.ups.com/
UPS_CLIENT_ID="your_ups_client_id"
UPS_CLIENT_SECRET="your_ups_client_secret"
UPS_ACCOUNT_NUMBER="your_ups_account_number"

# Use sandbox for testing
UPS_BASE_URL="https://www.ups.com"

# Internal Backend URL for Frontend API Router
BACKEND_URL="http://localhost:3000"
